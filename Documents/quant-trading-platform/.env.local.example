# IQuant - Environment Variables Template
# Copy this file to .env.local and add your actual API keys

# ============================================================================
# STOCK MARKET DATA APIs
# ============================================================================

# Alpha Vantage (Free tier: 25 requests/day)
# Sign up: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Polygon.io (Paid: Real-time stock & options data)
# Sign up: https://polygon.io/pricing
POLYGON_API_KEY=your_polygon_key_here

# Finnhub (Free tier available)
# Sign up: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# ============================================================================
# OPTIONS DATA APIs
# ============================================================================

# Tradier (Free with brokerage account)
# Sign up: https://developer.tradier.com/
TRADIER_API_KEY=your_tradier_key_here

# ============================================================================
# NEWS & SENTIMENT APIs (Optional)
# ============================================================================

# News API (Free tier: 100 requests/day)
# Sign up: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# ============================================================================
# TRADING EXECUTION (Optional - for live trading)
# ============================================================================

# Alpaca Trading API (Commission-free trading)
# Sign up: https://alpaca.markets/
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets # Use paper trading for testing

# Interactive Brokers
# IBKR_API_KEY=your_ibkr_key_here

# ============================================================================
# DATABASE (Optional - if you want to store data)
# ============================================================================

# PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/iquant

# MongoDB
# MONGODB_URI=mongodb://localhost:27017/iquant

# ============================================================================
# AUTHENTICATION (Optional - for multi-user support)
# ============================================================================

# NextAuth.js
# NEXTAUTH_URL=http://localhost:3001
# NEXTAUTH_SECRET=your_random_secret_here

# ============================================================================
# RATE LIMITING & CACHING
# ============================================================================

# Redis (for caching API responses)
# REDIS_URL=redis://localhost:6379

# ============================================================================
# RECOMMENDED STARTER SETUP (Free)
# ============================================================================
# 1. Get a free Alpha Vantage key
# 2. Uncomment and add your key above
# 3. Restart your dev server: npm run dev
# 4. Test with real data!

# ============================================================================
# RECOMMENDED PRODUCTION SETUP ($99-249/month)
# ============================================================================
# 1. Polygon.io for real-time stock & options data
# 2. News API for market sentiment
# 3. Optional: Alpaca for paper trading tests
